# Copy this file to .env.local for local development.
# For Vercel, add the relevant values in Project Settings -> Environment Variables.

# Required for production builds that refresh generated metadata and dataset caches.
API_KEY=
MARKETS_SERVER_URL=
NODE_OPTIONS=--max_old_space_size=8192
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=
NOT_VERCEL=1

# Public site settings.
NEXT_PUBLIC_SITE_URL=
# Comma-separated origins allowed for /api CORS. Use '*' only if API is intentionally public.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://defillama.com,https://www.defillama.com
# Set to true only for production deployments that should be indexed.
ROBOTS_ALLOW_INDEXING=

# Optional direct *_SERVER_URL overrides below take precedence over pro-api routing.
# Direct core, equities, and liquidations requests use proxy-style backend secrets server-side.
# EQUITIES_SECRET_KEY falls back to API2_SECRET_KEY when unset.
# Partial overrides are allowed; services without direct URLs keep the existing pro/public fallback.
API2_SECRET_KEY=
BRIDGES_SERVER_URL=
COINS_SERVER_URL=
DATASETS_SERVER_URL=
EQUITIES_SERVER_URL=
EQUITIES_SECRET_KEY=
ETF_SERVER_URL=
FDV_SERVER_URL=
LIQUIDATIONS_SECRET_KEY=
LIQUIDATIONS_SERVER_URL_V2=
RISK_SERVER_URL=
RWA_PERPS_SERVER_URL=
RWA_SERVER_URL=
SERVER_URL=
STABLECOINS_SERVER_URL=
TRADFI_API=
V2_SERVER_URL=
YIELDS_SERVER_URL=

# Optional runtime integrations.
CG_KEY=
DAT_API=
DISABLE_TELEMETRY=true
DL_NEWS_ACCESS_TOKEN=
DL_NEWS_API=
DO_NOT_TRACK=true
ENABLE_LLAMASWAP_PROTOCOLS_CHAINS=
EXT_REDIS_URL=
FRONT_VERIFICATION_SECRET=
IS_RUNTIME=
LLAMA_API_KEY=
LLAMA_DB_URL=
NEXT_PUBLIC_AUTH_SERVER_URL=
NEXT_PUBLIC_FEATURES_SERVER_URL=
NEXT_PUBLIC_SEARCH_API_TOKEN=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
OPS_TELEMETRY_TOKEN=
OPS_TELEMETRY_URL=
# Stable id for this deployment/probe target. Defaults to defillama if unset.
OPS_TELEMETRY_TARGET_ID=defillama
REDIS_URL=
# Shared secret guarding /api/private/revalidate-instances and authorizing the cross-instance fanout.
REVALIDATE_SECRET=
# Comma-separated direct base URLs of every serving Next.js instance, not the public load balancer (e.g. https://a.internal,https://b.internal). Requires REVALIDATE_SECRET; both must be set to activate.
REVALIDATE_INSTANCES=
ROUND_UP_BOT_TOKEN=
TASTY_API_KEY=
TASTY_API_URL=
USE_REDIS=

# Self-hosted deploy wrapper only; not required for standard Vercel Next.js deployments.
BUILD_DEPLOYMENT_NAME=
BUILD_NOTIFY_USERS=
BUILD_STATUS_WEBHOOK=
CF_PURGE_CACHE_AUTH=
CF_ZONE=
LOGGER_API_KEY=
LOGGER_API_URL=
RCLONE_CONFIG_ARTIFACTS_ACCESS_KEY_ID=
RCLONE_CONFIG_ARTIFACTS_ENDPOINT=
RCLONE_CONFIG_ARTIFACTS_SECRET_ACCESS_KEY=
