{
	"name": "defillama",
	"version": "1.0.0",
	"private": true,
	"homepage": "https://defillama.com",
	"license": "GPL-3.0-or-later",
	"sideEffects": false,
	"scripts": {
		"analyze": "bun --bun next experimental-analyze",
		"dev": "NODE_ENV=development bun run build:metadata && bun --bun next dev",
		"build:metadata": "sh ./scripts/buildMetadata.sh",
		"build": "NODE_ENV=production bun run build:metadata && bun --bun next build",
		"start": "./scripts/prestart.sh & bun --bun next start",
		"test": "vitest run",
		"test:types": "tsc -p tsconfig.vitest.json --noEmit",
		"format:check": "oxfmt --check",
		"format": "oxfmt --write",
		"lint": "oxlint",
		"ts": "tsc --noEmit"
	},
	"dependencies": {
		"@ariakit/react": "0.4.26",
		"@dnd-kit/core": "6.3.1",
		"@dnd-kit/modifiers": "9.0.0",
		"@dnd-kit/sortable": "10.0.0",
		"@duckdb/duckdb-wasm": "1.33.1-dev45.0",
		"@marsidev/react-turnstile": "1.5.0",
		"@monaco-editor/react": "4.7.0",
		"@rainbow-me/rainbowkit": "2.2.10",
		"@stripe/react-stripe-js": "6.2.0",
		"@stripe/stripe-js": "9.3.1",
		"@tailwindcss/typography": "0.5.19",
		"@tanstack/react-query": "5.100.5",
		"@tanstack/react-query-devtools": "5.100.5",
		"@tanstack/react-table": "8.21.3",
		"@tanstack/react-virtual": "3.13.24",
		"clsx": "2.1.1",
		"dayjs": "1.11.20",
		"dompurify": "3.4.1",
		"echarts": "6.0.0",
		"echarts-simple-transform": "1.0.0",
		"expr-eval": "2.0.2",
		"ioredis": "5.10.1",
		"lodash": "4.18.1",
		"match-sorter": "8.3.0",
		"monaco-editor": "0.55.1",
		"next": "16.2.4",
		"nprogress": "0.2.0",
		"pg-promise": "12.6.2",
		"pocketbase": "0.26.8",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-hot-toast": "2.6.0",
		"react-markdown": "10.1.0",
		"react-select": "5.10.2",
		"rehype-raw": "7.0.0",
		"rehype-sanitize": "6.0.0",
		"remark-gfm": "4.0.1",
		"textarea-caret": "3.1.0",
		"viem": "2.42.1",
		"wagmi": "2.19.5"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "4.2.4",
		"@types/dompurify": "3.0.5",
		"@types/lodash": "4.17.24",
		"@types/node": "25.6.0",
		"@types/react": "19.2.14",
		"babel-plugin-react-compiler": "1.0.0",
		"oxfmt": "0.46.0",
		"oxlint": "1.61.0",
		"oxlint-tsgolint": "0.22.0",
		"postcss": "8.5.12",
		"tailwindcss": "4.2.4",
		"typescript": "6.0.3",
		"vitest": "4.1.5"
	},
	"overrides": {
		"@types/react": "19.2.14"
	}
