{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["react", "react-perf", "typescript", "nextjs"],
	"categories": {
		"correctness": "error",
		"suspicious": "error"
	},
	"rules": {
		"eslint/eqeqeq": ["error", "always", { "null": "ignore" }],
		"eslint/no-fallthrough": "warn",
		"eslint/no-shadow": ["error", { "ignoreOnInitialization": true }],
		"eslint/no-throw-literal": "error",
		"eslint/prefer-const": "off",
		"eslint/preserve-caught-error": "off",
		"typescript/await-thenable": "warn",
		"typescript/no-extraneous-class": "off",
		"typescript/no-floating-promises": "warn",
		"typescript/no-misused-promises": "warn",
		"typescript/no-useless-default-assignment": "warn",
		"typescript/no-unused-vars": "warn",
		"typescript/prefer-find": "warn",
		"typescript/prefer-string-starts-ends-with": "warn",
		"typescript/require-await": "warn",
		"react/jsx-no-target-blank": "warn",
		"react/react-in-jsx-scope": "off",
		"react/rules-of-hooks": "error",
		"nextjs/no-duplicate-head": "off",
		"nextjs/no-html-link-for-pages": "off",
		"nextjs/no-img-element": "off"
	},
	"ignorePatterns": ["node_modules/**", ".next/**", "out/**", "build/**", "next-env.d.ts", "public/**", ".agents/**"]
}
