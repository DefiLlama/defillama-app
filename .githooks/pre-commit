#!/usr/bin/env sh

status=0

echo "Running bun run format..."
bun run format || status=$?

if [ "$status" -ne 0 ]; then
	echo "Pre-commit checks failed."
	exit "$status"
fi

echo "Running bun run lint, bun run typecheck, bun run test:typecheck, and bun run test in parallel..."

bun run lint &
lint_pid=$!

bun run typecheck &
typecheck_pid=$!

bun run test:typecheck &
test_typecheck_pid=$!

bun run test &
test_pid=$!

wait "$lint_pid" || status=$?
wait "$typecheck_pid" || status=$?
wait "$test_typecheck_pid" || status=$?
wait "$test_pid" || status=$?

if [ "$status" -ne 0 ]; then
	echo "Pre-commit checks failed."
	exit "$status"
fi
